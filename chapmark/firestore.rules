rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write only their own profile doc
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Per-book documents under each user
      match /books/{bookId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
